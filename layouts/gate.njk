{% extends "base.njk" %}

{% block content %}
<div class="gate">
  <h2 class="gate-title">{{ title }}</h2>

  <div class="two-column">
    <div class="column">
      <div class="symbol-row">
        <p>Symbol</p>
        <div class="symbol-box">${{ symbol }}$</div>
      </div>
      <div class="gate-description">
        <p><strong>Description:</strong></p>
        <p>{{ description | markdown | safe }}</p>
        <br>

        {% if notations %}
          <p><strong>Alternate notations:</strong></p>
          <ul>
            {% for n in notations %}
            <li>${{ n }}$</li>
            {% endfor %}
          </ul>
        {% endif %}
      </div>

      {% if sdks %}
        <h3>SDK Support</h3>
        <table class="sdk-table">
          <thead>
            <tr>
              <th>SDK</th>
              <th>Name</th>
            </tr>
          </thead>
          <tbody>
            {% for sdk in sdk_list %}
              {% set entry = sdks[sdk.key] %}
              <tr>
                <td>{{ sdk.label }}</td>
                {% if entry and entry.name %}
                  <td>
                    <a href="{{ entry.url }}"><code>{{ entry.name }}</code></a>
                    {% if entry.note %}
                      <span class="sdk-note" data-note="{{ entry.note }}">ⓘ</span>
                    {% endif %}
                  </td>
                {% else %}
                  <td class="sdk-unavailable">—</td>
                {% endif %}
              </tr>
            {% endfor %}
          </tbody>
        </table>
      {% endif %}
      {% if groups %}
        <h3>Groups</h3>
        <p>This gate is contained in the following groups:</p>
        <ul>
          {% for group in groups %}
          <li><a href="{{ ('/groups/' + group) | url }}">{{ group }}</a></li>
          {% endfor %}
        </ul>
      {% endif %}
    </div>

    <div class="column">
      {{ content | safe }}
    </div>
  </div>

  <br/>

  <a class="back-to-home" href="{{ '/' | url }}">Back to home</a>
  {% set githubPath = page.inputPath | replace('./', '') %}
  <p class="edit-on-github"><a href="https://github.com/natestemen/gate.directory/tree/main/{{ githubPath }}" target="_blank">Edit this page on GitHub</a></p>
</div>
{% endblock %}
